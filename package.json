{
  "name": "employee-portal",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c blue,magenta \"npm:dev -w backend\" \"npm:dev -w frontend\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "test": "npm test -w backend && npm test -w frontend",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:all": "npm test && npm run test:e2e",
    "typecheck": "npm run typecheck -w backend && npm run typecheck -w frontend",
    "db:migrate": "npm run db:migrate -w backend",
    "db:push": "npm run db:push -w backend",
    "db:seed": "npm run db:seed -w backend"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.7.5",
    "concurrently": "^8.2.2"
  }
}
