.git
.gitignore
.github
.claude
.idea
.vscode

# Workspaces have their own ignored deps; Dockerfiles run `npm install` inside the image
node_modules
backend/node_modules
frontend/node_modules

# Build / test outputs
backend/dist
frontend/dist
playwright-report
test-results
e2e/.cache

# Local databases & uploads — containers create fresh volumes
backend/prisma/dev.db
backend/prisma/dev.db-journal
backend/prisma/test.db*
backend/uploads/payslips/*
!backend/uploads/payslips/.gitkeep

# Local env — production secrets are injected via compose env_file / shell env
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Logs / OS noise
*.log
.DS_Store
Thumbs.db

# Docs / planning never need to be in the image
docs
README.md
Overview.md
