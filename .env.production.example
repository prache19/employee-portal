# Domain for Caddy HTTPS (Let's Encrypt). Must resolve to this server's public IP.
SITE_DOMAIN=employeeportal.your-domain.com

# JWT secrets — generate strong random values (min 32 chars each, 48+ recommended).
#   python3 -c "import secrets; print('JWT_ACCESS_SECRET=' + secrets.token_urlsafe(48))"
#   python3 -c "import secrets; print('JWT_REFRESH_SECRET=' + secrets.token_urlsafe(48))"
JWT_ACCESS_SECRET=<generate-a-strong-random-secret>
JWT_REFRESH_SECRET=<generate-a-strong-random-secret>

# Backup retention in days
BACKUP_RETENTION_DAYS=30
