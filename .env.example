# Backend
DATABASE_URL="file:./dev.db"
PORT=4000
NODE_ENV=development

JWT_ACCESS_SECRET="change-me-access-secret-please-32-chars-min"
JWT_REFRESH_SECRET="change-me-refresh-secret-please-32-chars-min"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

UPLOAD_DIR="./uploads"
CORS_ORIGIN="http://localhost:5173"

# Public URL of the frontend — used to build links in payslip-notification emails.
PORTAL_URL="http://localhost:8081"

# SMTP for payslip notifications. Leave SMTP_HOST blank to disable (the mailer
# logs "would send" instead). When running via `docker compose up`, the dev
# override auto-points the backend at a Mailhog container (UI: http://localhost:8025),
# so you can leave these commented out for local Node dev.
# SMTP_HOST="localhost"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Employee Portal <no-reply@employeeportal.local>"
# SMTP_SECURE="false"

# Frontend
VITE_API_BASE_URL="http://localhost:4000/api"
